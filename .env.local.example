# ─────────────────────────────────────────────
# Ludimente — variables de entorno
# Copia este archivo a .env.local y completa los valores.
# ─────────────────────────────────────────────

# Supabase (proyecto). Solo estas dos son públicas (NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role: SOLO en servidor (Edge Functions / Route Handlers privados).
# NUNCA exponer al cliente. No usar prefijo NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL pública del sitio (para enlaces del portal y emails).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (solo avisos internos del sistema). Opcional en Fase 1.
RESEND_API_KEY=
